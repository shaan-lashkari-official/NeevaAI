rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the owner can read/write their own document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Mood logs subcollection
      match /mood_logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Chat messages: client can read, only backend Admin SDK can write
      match /chat_messages/{msgId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // Admin SDK bypasses rules
      }

      // Exercise completions
      match /exercises/{exId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Community groups: authenticated users can read, update only post_count
    match /community_groups/{groupId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['post_count']);
      allow create, delete: if false; // Admin only
    }

    // Community posts: authenticated read/create, update only likes_count
    match /community_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes_count']);

      // Likes subcollection: user can only manage their own like doc
      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
